		$this->renderValueMode = false;
		return $out; 
	
		/*
		$value = $this->attr('value');	
		if(WireArray::iterable($value)) {
			return $this->value->render(array(
				'tableClass' => 'AdminDataList AdminDataTable'
			));
		} else {
			return $value; 
		}
		*/
	}

	/**
	 * Process input for the submitted table
	 * 
	 * Note: sanitization is done by FieldtypeTable::sanitizeValue()
	 *
	 * @param WireInputData $input
	 * @return $this
	 *
	 */
	public function ___processInput(WireInputData $input) {
		
		$languages = $this->wire()->languages;
		$datetime = $this->wire()->datetime;

		$rowNum = 0; 
		$rows = $this->attr('value'); /** @var TableRows $rows */
		$rowsArray = array();
		$rowsDelete = array();
		$field = $this->field;
		$fieldtype = $field->type; /** @var FieldtypeTable $fieldtype */
		$cols = $fieldtype->getColumnsByName($field); 
		$changes = array();
		$inputName = $this->attr('name');
		$numNewRows = 0;
		
		$deleteAllName = $inputName . '__delete_all'; 
		$deleteAll = $input->$deleteAllName;
		
		if($deleteAll === 'DELETE-ALL' && $rows && $field->get('paginationLimit') && $field->get('useBigDelete')) {
			if($rows->getTotal() > $rows->count()) {
				$numRows = $rows->getTotal();
				$page = $this->getPage();
				if($page && $page->id) {
					$fieldtype->deletePageField($page, $field);
					$this->message(sprintf($this->_('Deleted all %d rows for field "%s"'), $numRows, $field->name));
				}
				return $this;
			}
		}

		do {
			$rowNum++;
			$idName = $inputName . "_{$rowNum}__id";
			$id = $input->$idName; 
			if(is_null($id)) break;
			$id = (int) $id; 

			$deleteName = $inputName . "_{$rowNum}__delete";
			$delete = (int) $input->$deleteName; 

			$sortName = $inputName . "_{$rowNum}__sort";
			$sort = (int) $input->$sortName; 

			$row = $rows->eq($rowNum-1); /** @var TableRow $row */

			if($row && $delete) {
				$rowsDelete[] = $row;
				$changes[] = "delete-row-$rowNum";
			}
	
			if(is_null($row)) {
				if($delete) continue;
				$row = $rows->makeBlankItem();
				$changes[] = "add-row-$rowNum";
				$numNewRows++;
			}
			
			$row->id = $id;

			foreach($cols as $name => $col) {
				
				$type = $col['type'];
				if(!$name || !$type) continue; 
				
				$nameAttr = $inputName . "_{$rowNum}_$name";
				$valuePrevious = $row->$name;
				$value = $input->$nameAttr;
				$inputfield = null;
				$required = !empty($col['settings']['required']);
				
				if($type === 'date') {
					$value = $datetime->stringToTimestamp($value, $col['settings']['dateInputFormat']);
					
				} else if($type === 'datetime') {
					$a = $col['settings'];
					if(isset($a['inputType']) && isset($a['htmlType'])) {
						if($a['inputType'] === 'html' && $a['htmlType'] === 'datetime') {
							$timeValue = $input->{$nameAttr . '__time'};
							if($timeValue !== null) $value .= " $timeValue";
						}
					}
					$value = $datetime->stringToTimestamp($value, trim("$a[dateInputFormat] $a[timeInputFormat]"));
					
				} else if($type === 'time') {
					$value = (string) $value;
					if(!strlen($value)) {
						$value = null;
					} else if(!preg_match('/^\d\d:\d\d(:\d\d)?$/', $value)) {
						$value = strtotime("2022-12-15 $value"); 
						$value = $value === false ? null : date('H:i:s', $value);
					}
					
				} else if($type === 'checkbox') {
					$valuePrevious = ((int) $valuePrevious) ? 1 : 0;
					$value = ((int) $value) ? 1 : 0;

				} else if($type === 'textareaCKE') {
					$inputfield = $this->getCKEditorInputfield($nameAttr, $row->$name, $col);
					
				} else if($type === 'textareaMCE') {
					$inputfield = $this->getTinyMCEInputfield($nameAttr, $row->$name, $col);
					
				} else if($col['input'] === 'autocomplete') {
					$inputfield = $this->getPageAutocompleteInputfield($nameAttr, $row->$name, $col);

				} else if($col['input'] === 'textTags') {
					$inputfield = $this->getTextTagsInputfield($nameAttr, $row->$name, $col);
				
					/*
				} else if($type === 'toggle') {
					$inputfield = $this->getToggleInputfield($nameAttr, $row->$name, $col);
					*/
					
				} else if($col['input'] === 'file' || $col['input'] === 'image') {
					/** @var Pageimage|Pagefile|null $value */
					$value = $row->$name;
					$valuePrevious = $value;
					$value = $this->processInputFile($input, $nameAttr, $col, $value); 
				}
				
				if($inputfield) {
					$valuePrevious = $inputfield->attr('value');
					$inputfield->processInput($input);
					$value = $inputfield->attr('value');
				}
					
				// multi-language values
				if($col['valid'] === 'LanguagesPageFieldValue' && $languages) {
					$_value = $row->get($name); 
					if(!is_object($_value) || !$_value instanceof LanguagesValueInterface) {
						$_value = $fieldtype->newLanguagesPageFieldValue(new NullPage(), $field);
					}
					foreach($languages as $language) {
						/** @var Language $language */
						$_nameAttr = $language->isDefault() ? $nameAttr : $nameAttr . '__' . $language;
						if($type == 'textareaCKELanguage' || $type == 'textareaMCELanguage') {
							$getMethod = ($type == 'textareaCKELanguage' ? 'getCKEditorInputfield' : 'getTinyMCEInputfield');
							$inputfield = $this->$getMethod($_nameAttr, $_value->getLanguageValue($language), $col);
							if($inputfield) {
								$inputfield->processInput($input);
								$value = $inputfield->attr('value');
							}
						} else {
							$value = $input->$_nameAttr;
						}
						$_value->setLanguageValue($language, $value); 
					}
					$value = $_value; 
				}
	
				if($valuePrevious !== $value) {
					$a = array('value' => $value, 'valuePrevious' => $valuePrevious); 
					foreach($a as $k => $v) {
						if($v instanceof Page) {
							$v = (string) $v;
						} else if($v instanceof PageArray) {
							$v = $v->implode(',', 'id');
						} else if($v instanceof Pagefile) {
							$v = (string) $v;
						} else if(is_array($v)) {
							$v = implode(',', $v);
						} else if($v === null) {
							$v = '';
						} else if("$v" === "0") { 
							// note: toggle requires ability to use "0" 
							if(!in_array($type, [ 'toggle', 'float', 'decimal', 'double', 'int1', 'int2' ])) {
								$v = '';
							}
						}
						$a[$k] = $v;
					}
					if("$a[value]" != "$a[valuePrevious]") {
						$changes[] = "row-$rowNum-$name";
						$row->set($name, $value);
					}
				}
				
				if($required && !$delete && empty("$value")) {
					$this->error(sprintf(
						$this->_('Missing required value in “%1$s” row %2$d for column “%3$s”'),
						$this->field->label, $rowNum, "$col[label]"
					));
				}
				
				if(self::debug) {
					if(is_array($value)) $value = print_r($value, true); 
					$this->debugMessage("SET ROW $rowNum: $name=$value"); 
				}
			}
			while(isset($rowsArray[$sort])) $sort++;
			$rowsArray[$sort] = $row;
			
		} while(1);

		$keysPrevious = array_keys($rowsArray);
		ksort($rowsArray);
		$keys = array_keys($rowsArray);
		if($keys != $keysPrevious) $changes[] = 'sort';
		
		foreach($rowsArray as $row) $rows->add($row); 
		$this->debugMessage("Setting n rows: " . count($rows));

		/* the following prevents changes to existing rows from being saved (error)
		if(!$numNewRows) $rows->setTrackChanges(false);
		foreach($rowsArray as $row) $rows->add($row);
		if(!$numNewRows) $rows->setTrackChanges(true);
		*/
	
		if(count($rowsDelete)) {
			if($field->get('paginationLimit')) { // && $this->value->getTotal() > $this->value->count()) {
				$page = $this->getPage();
				if($page && $page->id) {
					$a = $fieldtype->getBlankValue($page, $field);
					foreach($rowsDelete as $row) {
						$a->add($row);
						$rows->remove($row);
					}
					$fieldtype->deletePageFieldRows($page, $field, $a);
				}
			} else {
				foreach($rowsDelete as $row) {
					$rows->remove($row);
				}
			}
		}

		$this->debugMessage("Setting n rows: " . count($rows)); 

		if(count($changes)) $this->trackChange('value');

		return $this; 
	}

	/**
	 * Process a file upload or action
	 * 
	 * @param WireInputData $input
	 * @param string $nameAttr
	 * @param array $col
	 * @param Pagefile|Pageimage|null $value
	 * @return Pagefile|Pageimage|null
	 * 
	 */
	protected function processInputFile(WireInputData $input, $nameAttr, array $col, $value) {
		
		$action = $input["{$nameAttr}__action"];
	
		if($action === 'delete') {
			if($value) $value->unlink();
			return null;
		}
		
		if(empty($_FILES[$nameAttr]['name'])) {
			return $value;
		}
		
		$page = $this->page;
		$field = $this->field;
		$fieldtype = $field->type; /** @var FieldtypeTable $fieldtype */
		$filesPath = $page->filesManager()->path();
		$extensions = explode(' ', $col['settings']['extensions']);
		
		$ul = new WireUpload($nameAttr);
		$this->wire($ul);
		
		$ul->setValidExtensions($extensions);
		$ul->setMaxFiles(1);
		$ul->setOverwrite(false);
		$ul->setDestinationPath($filesPath);
		$ul->setExtractArchives(false);
		$ul->setLowercase(true);
		
		$basenames = $ul->execute();
		
		if(count($basenames)) {
			if($value) $value->unlink(); // replace/delete existing file
			$basename = reset($basenames);
			$value = $fieldtype->wakeupFile($page, $field, $filesPath . $basename, $col['input']);
		} else {
			// no upload present, no change
		}
		
		return $value;
	}

	/**
	 * Get an instance of InputfieldCKEditor
	 *
	 * @param string $nameAttr
	 * @param string $value
	 * @param array $col
	 * @return InputfieldCKEditor|null
	 * 
	 */
	protected function getCKEditorInputfield($nameAttr, $value, array $col) {
		if(strpos($col['type'], 'CKE') === false) return null;
		$settings = $col['settings'];
		$f = isset($settings['settingsField']) ? $settings['settingsField'] : '';
		if($f) $f = $this->wire()->fields->get($f); /** @var Field $f */
		if(!$f || $f->get('inputfieldClass') != 'InputfieldCKEditor') return null;
		/** @var InputfieldCKEditor $cke */
		$cke = $f->getInputfield(new NullPage(), $f);
		if(!$cke) return null;
		$cke->attr('id+name', $nameAttr);
		$cke->set('configName', $settings['settingsField']);
		unset($settings['settingsField']);
		$cke->setArray($settings);
		$cke->useLanguages = false;
		$cke->usePurifier = true;
		$cke->inlineMode = 1; 
		$cke->attr('value', $value);
		return $cke;	
	}
	
	/**
	 * Get an instance of InputfieldTinyMCE
	 *
	 * @param string $nameAttr
	 * @param string $value
	 * @param array $col
	 * @return InputfieldTinyMCE|null
	 *
	 */
	protected function getTinyMCEInputfield($nameAttr, $value, array $col) {
		if(strpos($col['type'], 'MCE') === false) return null;
		$settings = $col['settings'];
		$f = isset($settings['settingsField']) ? $settings['settingsField'] : '';
		if($f) $f = $this->wire()->fields->get($f); /** @var Field $f */
		if(!$f || $f->get('inputfieldClass') != 'InputfieldTinyMCE') return null;
		/** @var InputfieldTinyMCE $mce */
		$mce = $f->getInputfield(new NullPage(), $f);
		if(!$mce) return null;
		$mce->attr('id+name', $nameAttr);
		$mce->set('configName', $settings['settingsField']);
		unset($settings['settingsField']);
		$settings['inlineMode'] = 1;
		$mce->setArray($settings);
		$mce->useLanguages = false;
		$mce->hasPage = $this->hasPage;
		//$mce->usePurifier = true;
		//$mce->inlineMode = 1;
		//$mce->lazyMode = 2;
		$mce->attr('value', $value);
		return $mce;
	}


	/**
	 * Get an instance of InputfieldPageAutocomplete
	 *
	 * @param string $nameAttr
	 * @param array $value
	 * @param array $col
	 * @return InputfieldPageAutocomplete|null
	 *
	 */
	protected function getPageAutocompleteInputfield($nameAttr, $value, array $col) {
		/** @var InputfieldPageAutocomplete $inputfield */
		$inputfield = $this->wire()->modules->get('InputfieldPageAutocomplete');
		if(!$inputfield) return null;
		$inputfield->attr('name', $nameAttr);
		$inputfield->attr('value', $value);
		$inputfield->findPagesSelector = $col['selector'];
		$labelField = $col['settings']['labelField'];
		if($this->wire()->sanitizer->fieldName($labelField) != $labelField) {
			$inputfield->labelFieldFormat = $labelField;
		} else {
			$inputfield->set('labelField', $labelField); // legacy/no longer used
			$inputfield->labelFieldName = $labelField;
		}
		
		$inputfield->searchFields = $col['settings']['searchField'];
		if($col['type'] == 'pageAutocomplete') {
			$inputfield->maxSelectedItems = 1;
			$inputfield->useList = false;
		}
		$this->setupInputfield($inputfield);
		return $inputfield; 
	}

	/**
	 * Get Toggle Inputfield
	 * 
	 * @param string $nameAttr
	 * @param int $value
	 * @param array $col
	 * @return null|InputfieldToggle
	 * 
	 */
	protected function getToggleInputfield($nameAttr, $value, array $col) {
		/** @var InputfieldToggle $inputfield */
		$inputfield = $this->wire()->modules->get('InputfieldToggle');
		if(!$inputfield) return null;
		if(ctype_digit("$value")) $value = (int) $value;
		$inputfield->attr('name', $nameAttr);
		foreach(array('labelType', 'useReverse', 'useOther', 'useDeselect') as $property) {
			$inputfield->$property = (int) $col['settings'][$property];
		}
		foreach(array('otherLabel', 'yesLabel', 'noLabel') as $property) {
			if(!empty($col['settings'][$property])) $inputfield->$property = $col['settings'][$property];
		}
		$defaultOption = strtolower($col['settings']['defaultOption']);
		if(in_array($defaultOption, array('yes', 'no', 'other', 'none'))) {
			$inputfield->defaultOption = $defaultOption;
		}
		$inputfield->attr('value', $value);
		$this->setupInputfield($inputfield);
		return $inputfield; 
	}

	/**
	 * Get TextTags Inputfield
	 * 
	 * @param string $nameAttr
	 * @param string|array $value
	 * @param array $col
	 * @return InputfieldTextTags|null
	 * 
	 */
	protected function getTextTagsInputfield($nameAttr, $value, array $col) {
		/** @var InputfieldTextTags $inputfield */
		$inputfield = $this->wire()->modules->get('InputfieldTextTags');
		if(!$inputfield) return null;
		$fieldtype = $this->field->type; /** @var FieldtypeTable $fieldtype */
		$inputfield->attr('name', $nameAttr);
		$tagsList = $fieldtype->sanitizeTextTags($col, '', 'tagsList');
		foreach($tagsList as $k => $v) {
			$inputfield->addOption($k, $v);
		}
		foreach($col['settings'] as $k => $v) {
			if($k === 'tagsList') continue;
			if(ctype_digit("$v")) $v = (int) $v;
			$inputfield->set($k, $v);
		}
		$value = $fieldtype->sanitizeTextTags($col, $value, 'string', false, $tagsList);
		$inputfield->val($value);
		$adminTheme = $this->wire()->adminTheme;
		$class = $adminTheme ? $adminTheme->getClass('input') : '';
		if($class) $inputfield->addClass($class);
		$this->setupInputfield($inputfield);
		return $inputfield;
	}

	/**
	 * Apply any common settings to Inputfields used for column inputs
	 * 
	 * @param Inputfield $inputfield
	 * @return Inputfield
	 * 
	 */
	protected function setupInputfield(Inputfield $inputfield) {
		if($this->field->get('useSmall')) {
			$inputfield->addClass('uk-form-small');
		}
		return $inputfield;
	}

	/**
	 * Get page being edited
	 * 
	 * @return NullPage|Page
	 * 
	 */
	public function getPage() {
		$process = $this->wire()->process;
		$page = $process instanceof WirePageEditor ? $process->getPage() : $this->hasPage;
		if(!$page) $page = new NullPage();
		return $page;
	}

	/**
	 * Allow user of table row actions?
	 * 
	 * @return bool
	 * 
	 */
	protected function useActions() {
		return $this->field->get('useActions') && !$this->field->get('paginationLimit');
	}

	/**
	 * Pages selectable pages for a Page input
	 * 
	 * Note: when hooking this, make sure that some 'selector' is defined in your column settings
	 * (even if just "id>0"), otherwise this method won't be called. 
	 * 
	 * ~~~~~
	 * $wire->addHookBefore('InputfieldTable::getSelectablePages', function(HookEvent $event) {
	 *   $field = $event->arguments(0); // Field object for Table field
	 *   $col = $event->arguments(1); // array of column information
	 *   $value = $event->arguments(2); // existing value as array of page IDs (if needed)
	 *
	 *   // exit if not the field or column we intend to override 
	 *   if($field->name != 'your_table_field_name') return;
	 *   if($col['name'] != 'your_page_column_name') return;
	 * 
	 *   if($col['input'] === 'autocomplete']) return; 
	 *     // autocomplete here should just convert value (array) of IDs to PageArray
	 *     // so we let the original method handle this
	 *     return;
	 *   }
	 * 
	 *   // perform our custom find
	 *   $event->return = $pages->find($col['selector']); 
	 * 
	 *   // prevent hooked method from being called
	 *   $event->replace = true; 
	 * }); 
	 * ~~~~~
	 * 
	 * @param Field $field The Table field this is being called for
	 * @param array $col Information for the Page-type column 
	 * @param array $value Existing value, array of page IDs
	 * @return PageArray
	 * @throws WireException
	 * 
	 */
	public function ___getSelectablePages(Field $field, array $col, array $value) {
		$pages = $this->wire()->pages;
		
		if($col['input'] === 'autocomplete') {
			$items = count($value) ? $pages->getById($value) : new PageArray();
		} else {
			$items = $pages->find($col['selector'], array('allowCustom' => true));
		}
		
		/*
		if(count($value)) {
			// allows previously selected unpublished/trashed value to continue to appear,
			// as suggested by SolutionInnovators
			foreach($this->wire()->pages->getById($value) as $item) {
				if(!$items->has($item)) $items->add($item);
			}
		}
		*/
		
		return $items;
	}
	
}