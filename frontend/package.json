    "prettier": "3.2.5",
    "sass": "1.76.0",
    "stylelint": "16.5.0",
    "stylelint-config-recess-order": "5.0.1",
    "stylelint-config-standard-scss": "13.1.0",
    "stylelint-config-standard-vue": "1.0.0"
  },
  "dependencies": {
